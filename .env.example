# claude-and-codex configuration
# You can use API keys OR OAuth (from CLI logins). OAuth is tried first.

# Direct API keys (fallback if OAuth tokens not found)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Model selection (optional)
CLAUDE_MODEL=claude-sonnet-4-20250514
CODEX_MODEL=gpt-4o

# Working directory for file operations (optional, defaults to cwd)
# WORKING_DIR=/path/to/your/project

# Agent behavior (optional)
# MAX_AGENT_TURNS=3
